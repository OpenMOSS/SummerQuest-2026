{
  "run": {
    "name": "train_owt"
  },
  "data": {
    "train_dataset": "artifacts/token_ids/owt_train.npy",
    "val_dataset": "artifacts/token_ids/owt_valid.npy",
    "vocab_path": "artifacts/owt_train_bpe/vocab.json",
    "merges_path": "artifacts/owt_train_bpe/merges.json",
    "special_tokens": ["<|endoftext|>"],
    "dataset_dtype": "uint16"
  },
  "model": {
    "vocab_size": 32000,
    "context_length": 512,
    "d_model": 768,
    "d_ff": 2048,
    "num_layers": 8,
    "num_heads": 8,
    "theta": 10000.0,
    "eps": 1e-5,
    "use_rope": true,
    "norm_mode": "pre",
    "ffn_type": "swiglu"
  },
  "optimizer": {
    "weight_decay": 0.0005,
    "betas": [0.9, 0.999],
    "eps": 1e-8,
    "grad_clip_max_norm": 1.0,
    "grad_clip_eps": 1e-6
  },
  "schedule": {
    "lr_max": 0.003,
    "lr_min_ratio": 0.05,
    "warmup_fraction": 0.025
  },
  "training": {
    "target_tokens": 2621440000,
    "batch_size": 128,
    "device": "auto",
    "dtype": null,
    "float32_matmul_precision": "high",
    "seed": 1337,
    "torch_compile": true,
    "compile_mode": "default",
    "autocast_dtype": "bfloat16",
    "max_wall_clock_sec": 5400,
    "log_every": 100,
    "print_every": 100
  },
  "validation": {
    "batch_size": 128,
    "every_tokens": 16384000,
    "max_tokens": 1048576
  },
  "checkpoint": {
    "enabled": true,
    "dir": "checkpoint/owt",
    "save_every": 5000,
    "save_best": true
  },
  "logging": {
    "path": "logs/train_owt.jsonl",
    "summary_path": "logs/train_owt.summary.json"
  },
  "stability": {
    "divergence_loss_threshold": 20.0
  }
}
