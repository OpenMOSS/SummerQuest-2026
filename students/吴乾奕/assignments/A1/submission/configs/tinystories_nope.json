{
  "run_name": "tinystories_nope",
  "seed": 42,
  "device": "cuda",
  "dtype": "bfloat16",
  "parameter_dtype": "float32",
  "amp": true,
  "compile": true,
  "data": {
    "train_tokens": "data/tinystories_train_tokens.npy",
    "validation_tokens": "data/tinystories_valid_tokens.npy",
    "tokenizer_dir": "artifacts/tokenizers/tinystories_10k"
  },
  "model": {
    "vocab_size": 10000,
    "context_length": 256,
    "d_model": 512,
    "d_ff": 1344,
    "num_layers": 4,
    "num_heads": 16,
    "rope_theta": 10000.0,
    "rms_norm_eps": 1e-5,
    "norm_style": "pre",
    "position_encoding": "none",
    "ffn_type": "swiglu"
  },
  "training": {
    "batch_size": 128,
    "gradient_accumulation_steps": 1,
    "max_steps": 10000,
    "gradient_clip": 1.0,
    "log_interval": 10,
    "validation_interval": 100,
    "validation_batches": 20,
    "validation_batch_size": 64,
    "checkpoint_interval": 500,
    "output_dir": "artifacts/runs/tinystories_nope",
    "resume_from": null
  },
  "optimizer": {
    "max_learning_rate": 0.0003,
    "min_learning_rate": 0.00003,
    "warmup_iters": 500,
    "cosine_cycle_iters": 10000,
    "beta1": 0.9,
    "beta2": 0.95,
    "eps": 1e-8,
    "weight_decay": 0.1
  }
}
