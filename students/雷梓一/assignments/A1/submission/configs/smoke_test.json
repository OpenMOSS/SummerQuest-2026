{
  "seed": 42,
  "device": "cpu",
  "train_path": "data/smoke_train.bin",
  "val_path": "data/smoke_valid.bin",
  "data_dtype": "uint16",
  "model": {
    "vocab_size": 512,
    "context_length": 32,
    "d_model": 64,
    "num_layers": 2,
    "num_heads": 4,
    "d_ff": 192,
    "rope_theta": 10000.0,
    "norm_style": "pre",
    "use_rope": true,
    "ffn_type": "swiglu"
  },
  "optimizer": {"lr": 0.001, "betas": [0.9, 0.95], "eps": 1e-8, "weight_decay": 0.1},
  "training": {
    "batch_size": 4,
    "max_steps": 10,
    "warmup_steps": 1,
    "min_lr": 0.0001,
    "max_grad_norm": 1.0,
    "eval_interval": 5,
    "eval_batches": 2,
    "checkpoint_interval": 10
  }
}
