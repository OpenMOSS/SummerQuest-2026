{
  "environment": {
    "python": "3.12.13",
    "pytorch": "2.10.0+cu128",
    "cuda_runtime": "12.8",
    "gpu": "NVIDIA GeForce RTX 4090",
    "gpu_memory_mib": 48639.3
  },
  "runs": [
