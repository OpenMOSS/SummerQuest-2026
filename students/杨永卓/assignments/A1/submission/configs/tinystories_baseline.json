{
  "run_name": "tinystories_baseline",
  "seed": 42,
  "device": "cuda",
  "output_dir": "runs/tinystories_baseline",
  "data": {
    "train": "data/tinystories_train.bin",
    "validation": "data/tinystories_valid.bin"
  },
  "model": {
    "vocab_size": 10000,
    "context_length": 256,
    "d_model": 512,
    "d_ff": 1344,
    "num_layers": 4,
    "num_heads": 16,
    "rope_theta": 10000.0
  },
  "training": {
    "batch_size": 128,
    "steps": 10000,
    "max_lr": 0.001,
    "min_lr": 0.0001,
    "warmup_steps": 500,
    "cosine_steps": 10000,
    "betas": [0.9, 0.95],
    "eps": 1e-8,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "amp_dtype": "bfloat16",
    "compile": false,
    "log_interval": 20,
    "val_interval": 250,
    "val_batches": 20,
    "checkpoint_interval": 1000
  }
}
